NODE_ENV=production
PORT=4001
# CORS_ORIGIN=http://localhost:3000
CORS_ORIGIN=http://108.129.175.80:3000


# PostgreSQL (Prisma)
DATABASE_URL=postgresql://urluser:urlpassword@postgres:5432/authdb?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# JWT Secrets — CHANGE IN PRODUCTION
JWT_ACCESS_SECRET=super-secret-access-key-change-me
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email — leave blank to use Ethereal (auto test account)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@urlshortener.app
