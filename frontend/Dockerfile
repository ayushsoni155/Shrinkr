# ── Stage 1: Dependencies ─────────────────────────────────────────
FROM node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

# ── Stage 2: Builder ──────────────────────────────────────────────
FROM node:20-alpine AS builder
WORKDIR /app
# Copy dependencies from the previous stage
COPY --from=deps /app/node_modules ./node_modules

# Ensure we copy EVERYTHING (including tsconfig.json, next.config.js, etc.)
COPY . .

# Explicitly check if tsconfig exists (debugging step, can be removed later)
RUN ls -la tsconfig.json

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

RUN npm run build

# ── Stage 3: Distroless Runtime ───────────────────────────────────
# Next.js standalone output is a self-contained Node.js server
FROM gcr.io/distroless/nodejs20-debian11

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Copy standalone Next.js server (generated by output: 'standalone')
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

# next.config.js output: 'standalone' generates server.js
CMD ["server.js"]
